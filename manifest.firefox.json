{
  "manifest_version": 3,
  "name": "Marginalia",
  "version": "2.1",
  "description": "Reading tracker and annotation tool",
  "browser_specific_settings": {
    "gecko": {
      "id": "marginalia@jwen",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["storage", "contextMenus", "activeTab", "tabs", "scripting", "alarms", "webNavigation"],
  "host_permissions": ["https://api.telegram.org/*", "https://api.github.com/*", "https://api.anthropic.com/*", "<all_urls>"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "options_page": "options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "lib/pdf.worker.min.mjs",
        "lib/marked.min.js",
        "lib/katex.min.js",
        "lib/katex.min.css",
        "lib/katex-fonts/*",
        "lib/dompurify.min.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
